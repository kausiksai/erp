# ============================================================================
# Email Automation — configuration template
# Copy to email_automation/.env and fill in real values.
# The .env file is gitignored (see email_automation/.gitignore and root .gitignore).
# ============================================================================

# ---- Postgres (production RDS) --------------------------------------------
PGHOST=your-rds-endpoint.rds.amazonaws.com
PGPORT=5432
PGDATABASE=billing_system
PGUSER=postgres
PGPASSWORD=CHANGE_ME
PGSSLMODE=require
PG_MIN_CONN=1
PG_MAX_CONN=4
PG_CONNECT_TIMEOUT=10

# ---- Zoho IMAP ------------------------------------------------------------
# Use an app-specific password from Zoho Mail -> Settings -> Security -> App Passwords.
IMAP_HOST=imap.zoho.in
IMAP_PORT=993
IMAP_SSL=true
IMAP_MAILBOX=INBOX
IMAP_USER=ATM@srimukhagroup.co.in
IMAP_PASSWORD=CHANGE_ME
# IMAP_ALLOWED_SENDER accepts a comma-separated list. Each address is
# searched independently; UIDs are merged & de-duplicated.
# kausiksai@outlook.com is a TEMPORARY additional source — remove it
# from the list once it's no longer needed (review ~ June 2026).
IMAP_ALLOWED_SENDER=srimukha.purchase@srimukhagroup.co.in,kausiksai@outlook.com

# ---- Alert SMTP (optional — enabled in Phase 4) ---------------------------
ALERT_ENABLED=false
ALERT_RECIPIENT=nandavsk@outlook.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Runtime --------------------------------------------------------------
TIMEZONE=Asia/Kolkata
WINDOW_START_HOUR=16
WINDOW_END_HOUR=18
LOG_LEVEL=INFO
