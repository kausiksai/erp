# ---- Database (same RDS as email_automation) -------------------------------
PGHOST=localhost
PGPORT=5432
PGDATABASE=billing_system
PGUSER=postgres
PGPASSWORD=change_me
PGSSLMODE=require
PG_MIN_CONN=1
PG_MAX_CONN=4
PG_CONNECT_TIMEOUT=10

# ---- Google Drive source ----------------------------------------------------
# Folder URL the suppliers / finance ops drop PDFs into.
# Folder ID = the segment after /folders/ in the URL.
DRIVE_FOLDER_ID=1296UDEc3BVoTQm_1k6pHlAV63yqam3jD

# Path to the service-account JSON key file (NOT committed to git).
# The folder must be shared (Viewer) with this service account's email.
GOOGLE_SERVICE_ACCOUNT_JSON=ocr_automation/credentials/service_account.json

# ---- Backend (the existing Node API) ----------------------------------------
# The OCR automation submits each PDF through the same /api/invoices/upload
# and /api/invoices endpoints the portal uses, so reconciliation runs server-
# side automatically.
BACKEND_BASE_URL=http://localhost:4000/api

# Optional: bearer token if your backend requires auth on these routes.
# Leave blank if internal-only.
BACKEND_AUTH_TOKEN=

# ---- Concurrency & retries --------------------------------------------------
OCR_CONCURRENCY=3
OCR_REQUEST_TIMEOUT_SECONDS=180
OCR_MAX_RETRIES=2

# ---- Runtime ----------------------------------------------------------------
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
