# Database Configuration (PostgreSQL / AWS RDS)
PGHOST=srimukha.chsm6aymy92r.ap-south-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=billing_system
PGUSER=postgres
PGPASSWORD=your_password_here
# For RDS, SSL is auto-enabled when host contains rds.amazonaws.com. Else set PGSSL=true if your server requires SSL.

# Server Configuration
PORT=4000
NODE_ENV=development
JSON_LIMIT=25mb

# Landing AI Agentic Document Extraction (ADE) — the ONLY invoice OCR path.
# Get your API key from https://va.landing.ai/settings/api-key (or the
# EU console at https://va.eu-west-1.landing.ai/settings/api-key).
# Pipeline: POST /v1/ade/parse → markdown → POST /v1/ade/extract with
# INVOICE_EXTRACTION_SCHEMA → structured JSON matching our invoice tables.
LANDING_AI_API_KEY=your_landing_ai_bearer_token_here
# Optional — region: "us" (default) or "eu"
# LANDING_AI_REGION=us
# Optional — model versions. Keep on "*-latest" for best extraction accuracy.
# LANDING_AI_PARSE_MODEL=dpt-2-latest
# LANDING_AI_EXTRACT_MODEL=extract-latest
# Optional — per-call timeout in ms (default 90000)
# LANDING_AI_TIMEOUT_MS=90000

# JWT Secret (generate a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Production: frontend origin for CORS when using custom domain (uncomment and set)
# FRONTEND_ORIGIN=http://srimukha.com:4000
# FRONTEND_ORIGIN=http://app.srimukha.com:4000

# Optional: rate limits (defaults: 200 req/15min API, 10/15min login)
# RATE_LIMIT_MAX=200
# LOGIN_RATE_LIMIT_MAX=10

# Optional: Default Admin User (used by createDefaultUser.js)
# DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_EMAIL=admin@srimukha.com
# DEFAULT_ADMIN_PASSWORD=Admin@123
# DEFAULT_ADMIN_ROLE=admin
